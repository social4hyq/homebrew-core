+            Ok(c) => c,
+            Err(_) => break 'shim None,
+        };
+        let arg_cs = match arg_b {
+            Some(a) => match std::ffi::CString::new(a) {
+                Ok(c) => Some(c),
+                Err(_) => break 'shim None,
+            },
+            None => None,
+        };
+        let mut owned: Vec<std::ffi::CString> = Vec::with_capacity(2);
+        let mut ptrs: Vec<*const c_char> = Vec::with_capacity(8);
